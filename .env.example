# NASA Earthdata credentials (required for SMAP ingestion)
# Create an account at https://urs.earthdata.nasa.gov
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=

# Maximum date range for ingestion requests (in days)
# Prevents accidental mass downloads
MAX_DAYS_RANGE=7

# ============================================================
# Backend API Layer (FastAPI)
# ============================================================

# PostgreSQL connection (async driver)
DATABASE_URL=postgresql+asyncpg://mse_user:mse_pass@postgres:5432/mse_platform

# Redis connection for cache layer
REDIS_URL=redis://redis:6379/1

# API Key for backend authentication (X-API-Key header)
BACKEND_API_KEY=dev-secret-key

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Default cache TTL in seconds
CACHE_TTL_DEFAULT=300
